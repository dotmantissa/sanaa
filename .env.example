# Sanaa AI Image Studio — Environment Variables
# Image generation uses Hugging Face FLUX.1-schnell

# Hugging Face Inference API token (free at huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here

# Deployed SanaaPayment contract address on Celo mainnet (set after deploying contracts)
NEXT_PUBLIC_CONTRACT_ADDRESS=

# App URL
NEXT_PUBLIC_APP_URL=https://sanaa-nu.vercel.app
