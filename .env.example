# Sanaa AI Image Studio — Environment Variables
# Copy this to .env.local and fill in your values

# Fal.ai API key for image generation (get at fal.ai)
FAL_API_KEY=your_fal_ai_key_here

# Deployed SanaaPayment contract address on Celo mainnet
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Optional: Deployed SanaaAgentRegistrar address
NEXT_PUBLIC_AGENT_ADDRESS=

# App URL (needed for MiniPay integration)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
